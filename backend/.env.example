# QuantEvo 后端环境变量配置

# ============================================
# 数据库
# ============================================
SQLITE_DB_PATH=./quant_trading.db

# ============================================
# LLM 配置 (三选一)
# ============================================

# 方案1: 本地 Qwen3-14B-MLX-4bit (推荐 Apple Silicon Mac)
LLM_BACKEND=mlx
QWEN_MLX_MODEL_PATH=/Users/macbookair/.cache/huggingface/hub/models--Qwen--Qwen3-14B-MLX-4bit/snapshots/ba63a5141812f9870287df53341123a71ba41433

# 方案2: OpenAI API
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# 方案3: Mock (开发测试用，无需模型)
# LLM_BACKEND=mock

# ============================================
# Embedding 配置 (三选一)
# ============================================

# 方案1: 本地 sentence-transformers
# EMBEDDING_BACKEND=sentence_transformers
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# 方案2: OpenAI Embedding
# EMBEDDING_BACKEND=openai
# EMBEDDING_MODEL=text-embedding-3-small

# 方案3: Mock (开发测试用)
EMBEDDING_BACKEND=mock

# ============================================
# CORS
# ============================================
BACKEND_CORS_ORIGINS=["*"]
